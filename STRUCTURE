#ifndef STRUCTURES_H
#define STRUCTURES_H

#define TAILLE_PAQUET 85

// Type de carte //

//enum est permet choix exclusif dans nos diff carte //
  typedef enum {
  NUM,  //0 a 12       //
  BONUS_MULT, //multiplie le score //
  BONUS_ADD  //ajoute des points        //
  } TypeCarte;


//Carte 

typedef struct {
  TypeCarte type;   // Categorie de la carte (NUM, BONUS_MULT, BONUS_ADD) //
  int       valeur; // numero de la carte      //                  
  } Carte;

//paquets Deck
typedef struct {
Carte cartes[TAILLE_PAQUET]; //  contenant toutes les cartes //
int   taille;                //Nombre de cartes encore disponible //
} Deck;


//Joueur //

typedef struct {
  char  nom[50];      
  Carte main[20];     // Cartes en main du joueur                   //
  int   nb_cartes;    // Nbrede cartes en main      //
  int   score_manche; // Score accumule de la manche  //
  int   score_total;  // Score total cumule sur toute la partie     //
  int   bonus_multi;  // Multiplicateur de score (base : 1)       //
  int   bonus_add;    // Bonus additif de score  (base : 0)       //
  } Joueur;

// Resultat mache //

typedef enum {
  MANCHE_CONTINUE,   // La manche continue normalement              //
  MANCHE_PERDUE,     // Le joueur a pioche un doublon donc score = 0   //
  MANCHE_GAGNEE      // Le joueur a 7 cartes differentes donc +15 pts  //
  } EtatManche;

#endif /* STRUCTURES_H */





